# Frontend
VITE_API_URL=http://127.0.0.1:8781
VITE_DEMO_EMAIL=demo@finflow.local
VITE_DEMO_PASSWORD=finflow-demo

# Backend local mode
FINFLOW_PROVIDER_MODE=MOCK
FINFLOW_STORE_MODE=sqlite
FINFLOW_SQLITE_PATH=data/finflow.sqlite3
FINFLOW_DATABASE_URL=
FINFLOW_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:4174,http://localhost:4174

# Webhook auth
# Local mock mode bypasses webhook auth by default. Set bypass false and provide
# a local-only token when testing locked webhooks.
FINFLOW_MOCK_BYPASS_WEBHOOK_AUTH=true
FINFLOW_WEBHOOK_TOKEN=

# Future live UiPath values: keep out of git and set only in a private .env.
UIPATH_TENANT_URL=
UIPATH_CLIENT_ID=
UIPATH_CLIENT_SECRET=
